# ============================================================
# DATABASE
# ============================================================
DATABASE_URL="postgresql://user:password@localhost:5432/revluma_prod"
DIRECT_URL="postgresql://user:password@localhost:5432/revluma_prod"

# ============================================================
# BASE URL CONFIGURATION (CRITICAL FOR AFFILIATE SYSTEM)
# ============================================================
# This controls all affiliate link generation, redirects, and email templates
# If domain changes, NO code changes required - only update this value
NEXT_PUBLIC_BASE_URL="https://revluma.vercel.app"
BASE_URL="https://revluma.vercel.app"
FRONTEND_URL="https://revluma.vercel.app"

# ============================================================
# ENVIRONMENT
# ============================================================
NODE_ENV="production"
PORT=5000

# ============================================================
# CORS & SECURITY
# ============================================================
CORS_ORIGINS="https://revluma.vercel.app,https://www.revluma.vercel.app"
ALLOWED_ORIGINS="https://revluma.vercel.app,https://www.revluma.vercel.app"

# ============================================================
# JWT/SESSION SECRETS (GENERATE WITH: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# ============================================================
JWT_SECRET="your-secure-jwt-secret-32-chars-min"
SESSION_SECRET="your-secure-session-secret-32-chars-min"
REFRESH_TOKEN_SECRET="your-secure-refresh-token-secret"

# ============================================================
# EMAIL SERVICE (Resend or SendGrid)
# ============================================================
EMAIL_PROVIDER="resend"
RESEND_API_KEY="re_..."
SENDGRID_API_KEY="SG..."

# For development/testing:
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@revluma.app"

# ============================================================
# REDIS (For sessions, caching, queues)
# ============================================================
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# ============================================================
# FILE STORAGE (Supabase Storage, S3, or local)
# ============================================================
STORAGE_PROVIDER="supabase"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-supabase-public-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
STORAGE_BUCKET="revluma-uploads"

# Alternative: AWS S3
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="us-east-1"
# AWS_S3_BUCKET="revluma-uploads"

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL="info"
LOG_FORMAT="json"

# ============================================================
# SENTRY (Error tracking)
# ============================================================
SENTRY_DSN=""
SENTRY_ENVIRONMENT="production"

# ============================================================
# ANALYTICS & TRACKING
# ============================================================
GOOGLE_ANALYTICS_ID=""

# ============================================================
# PAYMENT PROCESSING (Stripe for future)
# ============================================================
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ============================================================
# THIRD-PARTY INTEGRATIONS
# ============================================================
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""

# ============================================================
# AFFILIATE SYSTEM
# ============================================================
# Affiliate link expiration (days)
REFERRAL_LINK_EXPIRY_DAYS="365"
# Email verification expiration (hours)
EMAIL_VERIFICATION_EXPIRY_HOURS="24"
# Default affiliate commission rate
DEFAULT_COMMISSION_RATE="0.20"
