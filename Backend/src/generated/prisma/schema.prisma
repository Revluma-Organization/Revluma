
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // 👈 Tells Prisma to use this for db push/migrate
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

// ENUMS

enum Plan {
  STARTER
  GROWTH
  SCALE
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum Platform {
  SHOPIFY
  WOOCOMMERCE
  BIGCOMMERCE
}

enum SyncStatus {
  PENDING
  SYNCING
  SYNCED
  FAILED
}

// MODELS 

model Tenant {
  id          String     @id @default(uuid())
  companyName String     @map("company_name")
  plan        Plan       @default(STARTER)
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  // Relations
  users     User[]
  stores    Store[]
  customers Customer[]

  @@map("tenants")
}

model users {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  role          Role      @default(MEMBER)
  tenantId      String    @map("tenant_id")
  emailVerified Boolean   @default(false) @map("email_verified")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@index([tenantId])
  @@map("users")
}

model Store {
  id           String     @id @default(uuid())
  tenantId     String     @map("tenant_id")
  platform     Platform
  shopDomain   String     @unique @map("shop_domain")
  accessToken  String     @map("access_token")
  isConnected  Boolean    @default(true) @map("is_connected")
  syncStatus   SyncStatus @default(PENDING) @map("sync_status")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customers Customer[]

  @@index([tenantId])
  @@map("stores")
}

model Customer {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  storeId      String   @map("store_id")
  externalId   String   @map("external_id") // E.g., Shopify customer ID
  email        String
  phone        String?
  firstName    String?  @map("first_name")
  lastName     String?  @map("last_name")
  emailConsent Boolean  @default(false) @map("email_consent")
  smsConsent   Boolean  @default(false) @map("sms_consent")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store  Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, externalId])
  @@index([tenantId])
  @@map("customers")
}

model Session {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  token        String   @unique
  refreshToken String   @unique @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}